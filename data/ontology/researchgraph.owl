<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://researchgraph.ai/ontology"
         xmlns="http://researchgraph.ai/ontology#">

<owl:Ontology rdf:about="http://researchgraph.ai/ontology"/>

<owl:ObjectProperty rdf:about="#WRITTEN_BY">
  <rdfs:domain rdf:resource="#Paper"/>
  <rdfs:range rdf:resource="#Author"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#BELONGS_TO_TOPIC">
  <rdfs:domain rdf:resource="#Paper"/>
  <rdfs:range rdf:resource="#Topic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#USES_METHOD">
  <rdfs:domain rdf:resource="#Paper"/>
  <rdfs:range rdf:resource="#Method"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#REQUIRES_SKILL">
  <rdfs:domain rdf:resource="#Method"/>
  <rdfs:range rdf:resource="#Skill"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#RELATED_TO">
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#CITES">
  <rdfs:domain rdf:resource="#Paper"/>
  <rdfs:range rdf:resource="#Paper"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#INTERESTED_IN">
  <rdfs:range rdf:resource="#Topic"/>
  <rdfs:domain rdf:resource="#UserProfile"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#HAS_SKILL">
  <rdfs:range rdf:resource="#Skill"/>
  <rdfs:domain rdf:resource="#UserProfile"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#LACKS_SKILL">
  <rdfs:range rdf:resource="#Skill"/>
  <rdfs:domain rdf:resource="#UserProfile"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#USES_DATASET">
  <rdfs:domain rdf:resource="#Paper"/>
  <rdfs:range rdf:resource="#Dataset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#IN_AREA">
  <rdfs:domain rdf:resource="#Paper"/>
  <rdfs:range rdf:resource="#ResearchArea"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#SIMILAR_TO">
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#Paper">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Author">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Topic">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Method">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Skill">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Dataset">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#ResearchArea">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#UserProfile">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>


</rdf:RDF>
